# ─────────────────────────────────────────────
# Hi-Buddy Backend 환경변수
# 이 파일을 .env로 복사해서 실제 값을 입력하세요.
# Railway/Render 배포 시: 대시보드에서 환경변수로 설정
# ─────────────────────────────────────────────

# Gemini API (Google AI Studio에서 무료 발급)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Google API (Custom Search + YouTube)
GOOGLE_API_KEY=AIza...
GOOGLE_CSE_ID=...
YOUTUBE_API_KEY=AIza...

# 앱 인증 토큰 (Flutter 앱과 공유)
# 아무 랜덤 문자열 (예: openssl rand -hex 32)
APP_AUTH_TOKEN=your-secure-random-token-here

# Claude API (Anthropic) — v3.0 /api/agent 엔드포인트용 (선택, 1순위 LLM)
# https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-...
# 선택: 모델 지정 (기본값: claude-haiku-4-5-20251001)
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# Groq API (무료 14,400 req/일 · Llama 3.3 70B · Gemini 폴백용)
# https://console.groq.com → API Keys → Create
GROQ_API_KEY=gsk_...
# 선택: 모델 지정 (기본값: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# ── LLM 캐스케이드 우선순위 ──
# 1. Claude (있으면)
# 2. Gemini (무료 1,500/일)
# 3. Groq (무료 14,400/일)
# 4. 503 + 앱 오프라인 폴백

# Edge TTS 음성 (선택. 기본값: ko-KR-SunHiNeural)
# EDGE_TTS_VOICE=ko-KR-SunHiNeural
